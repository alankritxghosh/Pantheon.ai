PANTHEON_PROVIDER=ollama
PANTHEON_MODEL=qwen3:14b
OLLAMA_BASE_URL=http://localhost:11434
PANTHEON_OLLAMA_NUM_CTX=16384
PANTHEON_OLLAMA_CALL_TIMEOUT_MS=900000
PANTHEON_OLLAMA_FIRST_TOKEN_TIMEOUT_MS=360000
PANTHEON_EVIDENCE_ENRICHMENT=off
PANTHEON_ARTIFACT_MODEL_MODE=polish
# Optional:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7
# PANTHEON_MAX_TOKENS=64000
# PANTHEON_MAX_ITERATIONS=30
# PANTHEON_DISABLE_THINKING=0

# CLI providers. Override these if your local CLI syntax differs.
# PANTHEON_PROVIDER=claude-cli
# PANTHEON_CLAUDE_CLI_COMMAND=claude -p "$(cat "{{prompt_file}}")"

# PANTHEON_PROVIDER=openai-cli
# OPENAI_MODEL=gpt-5.2
# PANTHEON_OPENAI_CLI_COMMAND=openai responses create -m "{{model}}" -i "$(cat "{{prompt_file}}")"

# PANTHEON_PROVIDER=gemini-cli
# GEMINI_MODEL=gemini-2.5-pro
# PANTHEON_GEMINI_CLI_COMMAND=gemini --model "{{model}}" -p "$(cat "{{prompt_file}}")"
